# =============================================================================
# Project Zomboid ARM64 Server — Environment Variables
# Copy this file to .env and customize before starting the container.
# =============================================================================
#
# Categories (from upstream indifferentbroccoli convention):
#   User      — PUID/PGID for file ownership
#   Memory    — JVM heap sizing (MEMORY_XMX_GB preferred, MEMORY fallback)
#   Important — Must-change credentials (Password, RCON, Admin)
#   Mod       — Workshop mods and items
#   Server    — All gameplay tuning (PZ server.ini settings)
#   Anti-Cheat — Anti-cheat protection toggles and thresholds
#   ARM       — ARM64-specific extras (Box64, device, fallback mode)

# =============================================================================
# [User] — File ownership on mounted volumes
# =============================================================================
PUID=1000
PGID=1000

# =============================================================================
# [Memory] — JVM Heap Sizing
# =============================================================================
# Preferred: explicit GB values (default 8 GB Xmx, Xms optional)
MEMORY_XMX_GB=8
MEMORY_XMS_GB=
# Legacy fallback (used if MEMORY_XMX_GB is empty): e.g. 2G, 4G, 8192M
MEMORY=2G

# =============================================================================
# [Important] — Must change before public server
# =============================================================================
PASSWORD=CHANGEME
RCON_PASSWORD=changeme
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# =============================================================================
# [Mod] — Workshop mods
# =============================================================================
# Semicolon-separated lists; leave empty for vanilla
MODS=
WORKSHOP_ITEMS=

# =============================================================================
# [Server] — Gameplay settings (maps to Server/<SERVER_NAME>.ini)
# =============================================================================

# --- Identity ---
SERVER_NAME=pzserver
SERVER_BROWSER_ANNOUNCED_IP=
SERVER_WELCOME_MESSAGE=Welcome to your Project Zomboid Docker server
# SERVER_PUBLIC is compose-safe primary; PUBLIC is backwards-compatible alias for direct Docker run
SERVER_PUBLIC=true
PUBLIC_NAME=Project Zomboid Server
PUBLIC_DESCRIPTION=Welcome to your Project Zomboid Docker server
SERVER_PLAYER_ID=88635698
RESET_ID=563979383
MAX_PLAYERS=32

# --- Network ---
DEFAULT_PORT=16261
UDP_PORT=16262
RCON_PORT=27015
PING_LIMIT=400

# --- Gameplay Toggles ---
PVP=true
PAUSE_EMPTY=true
GLOBAL_CHAT=true
OPEN=true
SAFETY_SYSTEM=true
SHOW_SAFETY=true
SAFETY_TOGGLE_TIMER=2
SAFETY_COOLDOWN_TIMER=3
DO_LUA_CHECKSUM=true
DENY_LOGIN_ON_OVERLOADED_SERVER=false
NO_FIRE=false
ANNOUNCE_DEATH=false
ALLOW_DESTRUCTION_BY_SLEDGEHAMMER=true
SLEDGEHAMMER_ONLY_IN_SAFEHOUSE=false
KICK_FAST_PLAYERS=false
ALLOW_COOP=true
SLEEP_ALLOWED=false
SLEEP_NEEDED=false
KNOCKED_DOWN_ALLOWED=true
SNEAK_MODE_HIDE_FROM_OTHER_PLAYERS=true
STEAM_SCOREBOARD=true
STEAM_VAC=true
UPNP=true
VOICE_ENABLE=true
VOICE_3D=true
FACTION=true
DISABLE_RADIO_STAFF=false
DISABLE_RADIO_ADMIN=false
DISABLE_RADIO_GM=false
DISABLE_RADIO_OVERSEER=false
DISABLE_RADIO_MODERATOR=false
DISABLE_RADIO_INVISIBLE=false
ALLOW_NON_ASCII_USERNAME=false
BAN_KICK_GLOBAL_SOUND=true
REMOVE_PLAYER_CORPSES_ON_CORPSE_REMOVAL=false
TRASH_DELETE_ALL=false
PVP_MELEE_WHILE_HIT_REACTION=false
MOUSE_OVER_TO_SEE_DISPLAY_NAME=true
HIDE_PLAYERS_BEHIND_YOU=true
PLAYER_BUMP_PLAYER=false
LOGIN_QUEUE_ENABLED=false
PLAYER_RESPAWN_WITH_SELF=false
PLAYER_RESPAWN_WITH_OTHER=false
DISABLE_SAFEHOUSE_WHEN_PLAYER_CONNECTED=false
AUTO_CREATE_USER_IN_WHITE_LIST=false
DISPLAY_USER_NAME=true
SHOW_FIRST_AND_LAST_NAME=false

# --- Numeric Tuning ---
HOURS_FOR_LOOT_RESPAWN=0
MAX_ITEMS_FOR_LOOT_RESPAWN=4
CONSTRUCTION_PREVENTS_LOOT_RESPAWN=false
DROP_OFF_WHITE_LIST_AFTER_DEATH=false
MINUTES_PER_PAGE=1.0
SAVE_WORLD_EVERY_MINUTES=0
VOICE_MIN_DISTANCE=10.0
VOICE_MAX_DISTANCE=100.0
SPEED_LIMIT=70.0
FAST_FORWARD_MULTIPLIER=40.0
LOGIN_QUEUE_CONNECT_TIMEOUT=60
PVP_MELEE_DAMAGE_MODIFIER=30.0
PVP_FIREARM_DAMAGE_MODIFIER=50.0
CAR_ENGINE_ATTRACTION_MODIFIER=0.5
MAP_REMOTE_PLAYER_VISIBILITY=1
ITEM_NUMBERS_LIMIT_PER_CONTAINER=0
BLOOD_SPLAT_LIFESPAN_DAYS=0
BACKUPS_COUNT=5
BACKUPS_PERIOD=0
BACKUPS_ON_START=true
BACKUPS_ON_VERSION_CHANGE=true
MAX_ACCOUNTS_PER_USER=0

# --- Safehouse ---
PLAYER_SAFEHOUSE=false
ADMIN_SAFEHOUSE=false
SAFEHOUSE_ALLOW_TRESPASS=true
SAFEHOUSE_ALLOW_FIRE=true
SAFEHOUSE_ALLOW_LOOT=true
SAFEHOUSE_ALLOW_RESPAWN=false
SAFEHOUSE_DAY_SURVIVED_TO_CLAIM=0
SAFEHOUSE_REMOVAL_TIME=144
SAFEHOUSE_ALLOW_NON_RESIDENTIAL=false

# --- Factions ---
FACTION_DAY_SURVIVED_TO_CREATE=0
FACTION_PLAYERS_REQUIRED_FOR_TAG=1

# --- Discord Integration ---
DISCORD_ENABLE=false
DISCORD_TOKEN=
DISCORD_CHANNEL=
DISCORD_CHANNEL_ID=

# --- Chat / Logs ---
CHAT_STREAMS=s,r,a,w,y,sh,f,all
CLIENT_COMMAND_FILTER=-vehicle.*;+vehicle.damageWindow;+vehicle.fixPart;+vehicle.installPart;+vehicle.uninstallPart
CLIENT_ACTION_LOGS=ISEnterVehicle;ISExitVehicle;ISTakeEngineParts;
PERK_LOGS=true

# --- Spawn ---
SPAWN_POINT=0,0,0
SPAWN_ITEMS=
MAP=

# =============================================================================
# [Anti-Cheat] — Protection toggles and thresholds
# =============================================================================
# Types 1-24 toggle anti-cheat checks (true=enabled)
ANTI_CHEAT_PROTECTION_TYPE1=true
ANTI_CHEAT_PROTECTION_TYPE2=true
ANTI_CHEAT_PROTECTION_TYPE3=true
ANTI_CHEAT_PROTECTION_TYPE4=true
ANTI_CHEAT_PROTECTION_TYPE5=true
ANTI_CHEAT_PROTECTION_TYPE6=true
ANTI_CHEAT_PROTECTION_TYPE7=true
ANTI_CHEAT_PROTECTION_TYPE8=true
ANTI_CHEAT_PROTECTION_TYPE9=true
ANTI_CHEAT_PROTECTION_TYPE10=true
ANTI_CHEAT_PROTECTION_TYPE11=true
ANTI_CHEAT_PROTECTION_TYPE12=true
ANTI_CHEAT_PROTECTION_TYPE13=true
ANTI_CHEAT_PROTECTION_TYPE14=true
ANTI_CHEAT_PROTECTION_TYPE15=true
ANTI_CHEAT_PROTECTION_TYPE16=true
ANTI_CHEAT_PROTECTION_TYPE17=true
ANTI_CHEAT_PROTECTION_TYPE18=true
ANTI_CHEAT_PROTECTION_TYPE19=true
ANTI_CHEAT_PROTECTION_TYPE20=true
ANTI_CHEAT_PROTECTION_TYPE21=true
ANTI_CHEAT_PROTECTION_TYPE22=true
ANTI_CHEAT_PROTECTION_TYPE23=true
ANTI_CHEAT_PROTECTION_TYPE24=true

# Threshold multipliers (subset of types that support it)
# _THRESHOLD is a shorter alias for _THRESHOLD_MULTIPLIER (supported in compose and direct run)
ANTI_CHEAT_PROTECTION_TYPE2_THRESHOLD_MULTIPLIER=3.0
ANTI_CHEAT_PROTECTION_TYPE3_THRESHOLD_MULTIPLIER=1.0
ANTI_CHEAT_PROTECTION_TYPE4_THRESHOLD_MULTIPLIER=1.0
ANTI_CHEAT_PROTECTION_TYPE9_THRESHOLD_MULTIPLIER=1.0
ANTI_CHEAT_PROTECTION_TYPE15_THRESHOLD_MULTIPLIER=1.0
ANTI_CHEAT_PROTECTION_TYPE20_THRESHOLD_MULTIPLIER=1.0
ANTI_CHEAT_PROTECTION_TYPE22_THRESHOLD_MULTIPLIER=1.0
ANTI_CHEAT_PROTECTION_TYPE24_THRESHOLD_MULTIPLIER=6.0

# =============================================================================
# [ARM] — ARM64-specific extras
# =============================================================================

# --- Server Update ---
# Project Zomboid branch (leave empty for stable).
# Accepts SERVER_BRANCH as backwards-compatible alias.
# Examples: b41multiplayer, b42test, unstable
BRANCH=
SERVER_BRANCH=
UPDATE_ON_START=true
DISABLE_STEAM=false

# --- Server Config Generation ---
# true:  Patch Server/<SERVER_NAME>.ini idempotently from env vars on each start
# false: Preserve user edits, only write minimal required fields
GENERATE_SETTINGS=true

# --- Box64 Dynarec Tuning ---
# Big block optimization (default: 1). Set to 0 if crashes.
BOX64_DYNAREC_BIGBLOCK=1
# Bleeding edge optimizations (default: 0). Experimental.
BOX64_DYNAREC_BLEEDING_EDGE=0
# Additional Box64 knobs exposed for troubleshooting
BOX64_DYNAREC_BB_LOOP=1
BOX64_DYNAREC_FORWARD=1
BOX64_DYNAREC_STRONGMEM=1

# --- ARM Hardware ---
# Set to raspberry-pi-4, raspberry-pi-5, apple-silicon, graviton, etc.
# Currently informational; may tune Box64 settings per device in future.
ARM64_DEVICE=

# --- Runtime Mode ---
# Use Java fallback instead of Box64 launcher (true/false)
# Required if ProjectZomboid64 binary becomes incompatible after game update
USE_JAVA_FALLBACK=false
# Extra JVM arguments (appended in Java fallback mode)
# Example: -XX:+UseZGC -Djava.awt.headless=true
JAVA_EXTRA_ARGS=
